# Configuración de acceso a la API de Radiobot/AzuraCast
# Copia este archivo como radiobot.conf y rellena los valores reales.
# IMPORTANTE: radiobot.conf está en .gitignore y nunca debe subirse al repositorio.

AZURACAST_API_URL=https://radiobot.tudominio.com/api
AZURACAST_API_KEY=tu_clave_api_aqui
