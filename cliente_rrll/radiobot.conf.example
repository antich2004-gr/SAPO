# Configuración del cliente RRLL
# Copia este archivo como radiobot.conf y ajusta la ruta.
# IMPORTANTE: radiobot.conf está en .gitignore y nunca debe subirse al repositorio.

# Ruta al archivo global.json de la instalación de SAPO.
# La API key y URL de Radiobot se leen automáticamente desde ahí.
SAPO_GLOBAL_JSON=/var/www/sapo/db/global.json
